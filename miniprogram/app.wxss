/** app.wxss **/

/* ===== 容器 ===== */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

/* ===== 按钮重置 ===== */
button {
  background: initial;
}

button:focus {
  outline: 0;
}

button::after {
  border: none;
}

/* ===== 页面基底 ===== */
page {
  background: #f8f8f8;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

/* ===== 主题色 ===== */
.theme-color {
  color: #ff6b35;
}
.theme-bg {
  background: #ff6b35;
}

/* ===== 通用安全区 ===== */
.safe-padding-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===== 文字溢出 ===== */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* ===== 价格展示 ===== */
.price {
  color: #ff6b35;
  font-weight: 700;
}
.price::before {
  content: '¥';
  font-size: 0.7em;
}
